{
  "manifest_version": 3,
  "name": "TabQ",
  "version": "1.0.0",
  "description": "Badges the favicon of the first 9 tabs in each window with their number (1-9) to mirror Chrome's Ctrl/Cmd+1..9 jump shortcuts.",
  "homepage_url": "https://github.com/your-username/tabq",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TabQ - numbered tab favicons",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ]
}
